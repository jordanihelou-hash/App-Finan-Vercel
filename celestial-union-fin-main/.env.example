# ─────────────────────────────────────────────────────────────────────────────
# Cofre do Casal — Variáveis de Ambiente
#
# 1. Copie este arquivo para .env.local (nunca versione o .env.local!)
# 2. Preencha com os valores do seu projeto Supabase
# 3. No Vercel: adicione as mesmas variáveis em Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — Project URL e chave pública (anon key)
# Encontre em: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Gemini AI — chave para o advisor financeiro (opcional)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
